{
  "color": {
    "brand": {
      "primary": {
        "500": "#7B3EFC",
        "contrast": "#FFFFFF"
      },
      "secondary": {
        "500": "#000000",
        "contrast": "#FFFFFF"
      }
    },
    "semantic": {
      "success": {
        "default": "#CCFF00",
        "contrast": "#000000"
      },
      "warning": {
        "default": "#FF5415",
        "contrast": "#FFFFFF"
      },
      "background": {
        "light": "#FFFFFF",
        "dark": "#000000"
      }
    },
    "border": {
      "subtle": {
        "light": "#E5E5E5",
        "dark": "#1A1A1A"
      },
      "strong": {
        "light": "#000000",
        "dark": "#FFFFFF"
      }
    }
  },
  "typography": {
    "family": {
      "display": "'VT323', 'Press Start 2P', monospace",
      "sans": "'Inter', 'Space Grotesk', sans-serif",
      "mono": "'Fira Code', 'Roboto Mono', monospace"
    },
    "size": {
      "sm": "14px",
      "base": "16px",
      "lg": "20px",
      "h2": "32px",
      "h1": "48px",
      "display": "64px"
    },
    "lineHeight": {
      "tight": "1.1",
      "snug": "1.2",
      "normal": "1.5"
    }
  },
  "spacing": {
    "0": "0px",
    "1": "4px",
    "2": "8px",
    "3": "16px",
    "4": "24px",
    "5": "32px",
    "6": "48px",
    "7": "64px",
    "8": "96px"
  },
  "layout": {
    "container": {
      "maxWidth": "100%",
      "paddingX": "0px"
    },
    "grid": {
      "bleed": "true"
    }
  },
  "radius": {
    "none": "0px",
    "full": "0px"
  },
  "shadow": {
    "none": "none",
    "solid": "4px 4px 0px 0px var(--color-brand-secondary-500)"
  },
  "motion": {
    "duration": {
      "instant": "0ms",
      "fast": "100ms"
    },
    "easing": {
      "mechanical": "linear"
    }
  }
}